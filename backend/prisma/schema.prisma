generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Donor {
  id             String     @id @default(cuid())
  donorId        String     @unique // e.g., DNR1023
  email          String     @unique
  name           String?
  mobile         String?
  password       String?    // Hashed password for secure access
  pan            String?
  address        String?
  tier           String     @default("DONOR") // Enum DonorTier: DONOR, PATRON, CHAMPION
  totalDonated   Float      @default(0)
  otpHash        String?
  otpExpiry      DateTime?
  donations      Donation[]
  isEligible     Boolean    @default(false)
  isVolunteer    Boolean    @default(false)
  isNonDonor     Boolean    @default(false)
  referredById   String?
  referredBy     Donor?     @relation("Referrals", fields: [referredById], references: [id])
  referrals      Donor[]    @relation("Referrals")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Donation {
  id                String   @id @default(cuid())
  amount            Float
  currency          String   @default("INR")
  status            String   @default("PENDING") // Enum DonationStatus: PENDING, SUCCESS, FAILED
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?
  donorId           String
  donor             Donor    @relation(fields: [donorId], references: [id])
  programId         String
  program           Program  @relation(fields: [programId], references: [id])
  displayName       Boolean  @default(true)
  receiptNumber     String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Program {
  id           String     @id @default(cuid())
  name         String     @unique
  description  String
  targetAmount Float
  raisedAmount Float      @default(0)
  donations    Donation[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  author    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ImpactMetrics {
  id                String @id @default("global")
  totalRaised       Float  @default(0)
  totalUtilized     Float  @default(0)
  childrenImpacted  Int    @default(0)
  schoolsReached    Int    @default(0)
  healthCheckups    Int    @default(0)
  programsSupported Int    @default(0)
}

model AdvisoryApplication {
  id                    String   @id @default(cuid())
  firstName             String
  lastName              String
  mobile                String
  email                 String
  state                 String
  city                  String
  linkedInUrl           String?
  designation           String
  organization          String
  
  primaryDomains        String[]
  secondaryDomains      String[]
  customDomain          String?
  
  experienceYears       String
  qualification         String
  expertiseSummary      String
  majorAchievements     String
  
  photoUrl              String
  cvUrl                 String
  bioUrl                String
  idProofUrl            String
  qualificationProofUrl String
  registrationUrl       String
  
  whyJoin               String
  valueProposition      String
  expectations          String
  
  status                String   @default("PENDING") // Enum: PENDING, APPROVED, REJECTED
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
